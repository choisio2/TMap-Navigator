<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">


    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="250dp"
        android:gravity="center"
        android:text="AIVY Navigator"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:textSize="16sp"
        android:text="TMap API 사용해서 구현"
        android:textColor="#C9C9CB"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle" />


    <Button
        android:id="@+id/btnNaverMaps"
        android:layout_width="220dp"
        android:layout_height="55dp"
        app:backgroundTint="@null"
        android:backgroundTint="#44D34A"
        android:text="네이버 지도 열기"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconSize="20dp"
        android:layout_marginTop="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

    <Button
        android:id="@+id/btnTmap"
        android:layout_width="220dp"
        android:layout_height="55dp"
        app:backgroundTint="@null"
        android:backgroundTint="#0097E0"
        android:text="TMap으로 길찾기"
        android:textColor="@color/white"
        android:textSize="15sp"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconSize="20dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnNaverMaps" />


</androidx.constraintlayout.widget.ConstraintLayout>